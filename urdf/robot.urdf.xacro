<?xml version="1.0" ?>
<robot name="proscenic_m6pro" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:include filename="params.xacro" />
  <xacro:include filename="inertial.xacro" />
  <xacro:include filename="plugins.xacro" />
  <xacro:include filename="materials.xacro" />

  <!-- ****************** **************** ****************** -->

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${floor_clearance}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${lower_cylinder_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${lower_cylinder_height}" radius="${base_diameter/2}"/>
      </geometry>
      <material name="light_gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${lower_cylinder_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${lower_cylinder_height}" radius="${base_diameter/2}"/>
      </geometry>
    </collision>

    <xacro:solid_cylinder_inertia m="${lower_cylinder_mass}" r="${base_diameter/2}" h="${lower_cylinder_height}"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="${caster_inset-base_diameter/2} 0 ${caster_diameter/2-floor_clearance}" rpy="0 0 0"/>
  </joint>

  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_diameter/2}"/>
      </geometry>
      <material name="light_gray"/>
    </visual>

   <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_diameter/2}"/>
      </geometry>
    </collision>

    <xacro:solid_sphere_inertia m="${caster_mass}" r="${caster_diameter/2}"/>
  </link>


  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0 ${wheel_base/2} ${wheel_diameter/2-floor_clearance}" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1">
      <limit>
        <effort>${motor_stall_torque}</effort>
      </limit>
    </axis>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${wheel_width}" radius="${wheel_diameter/2}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${wheel_width}" radius="${wheel_diameter/2}"/>
      </geometry>
    </collision>

    <xacro:solid_cylinder_inertia m="${wheel_mass}" r="${wheel_diameter/2}" h="${wheel_width}"/>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 ${-wheel_base/2} ${wheel_diameter/2-floor_clearance}" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1">
      <limit>
        <effort>${motor_stall_torque}</effort>
      </limit>
    </axis>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${wheel_width}" radius="${wheel_diameter/2}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${wheel_width}" radius="${wheel_diameter/2}"/>
      </geometry>
    </collision>

    <xacro:solid_cylinder_inertia m="${wheel_mass}" r="${wheel_diameter/2}" h="${wheel_width}"/>
  </link>


  <!-- Upright top-mounted LiDAR turret (+Z up, CCW scan) to match both the
       Gazebo gpu_lidar sensor and the physical robot's vacuum_ros2_bridge /scan. -->
  <joint name="scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="${lidar_center_offset} 0 ${lower_cylinder_height + laser_puck_offset}" rpy="0 0 0"/>
  </joint>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${laser_puck_height}" radius="${laser_puck_diameter/2}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="${laser_puck_height}" radius="${laser_puck_diameter/2}"/>
      </geometry>
    </collision>

    <xacro:solid_cylinder_inertia m="${laser_puck_mass}" r="${laser_puck_diameter/2}" h="${laser_puck_height}"/>
  </link>

</robot>
