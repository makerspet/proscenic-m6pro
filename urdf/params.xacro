<?xml version="1.0" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- ****************** ROBOT DIMENSIONS ****************** -->
  <!-- Units: meters, degrees, kg, N*m, m/s2 -->
  <!-- Proscenic M6 Pro: round body 349mm dia (measured), ~95mm tall (incl. LiDAR turret). -->
  <!-- wheel_base = measured wheel track 235mm. The bridge uses its own odometry
       constant WHEEL_BASE = 0.233m (2mm less); negligible, calibrate empirically. -->
  <xacro:property name="wheel_diameter" value="0.068"/>
  <xacro:property name="wheel_width" value="0.012"/>
  <xacro:property name="caster_diameter" value="0.025"/>
  <!-- Caster center to base edge -->
  <xacro:property name="caster_inset" value="0.030"/>
  <xacro:property name="floor_clearance" value="0.0125"/>
  <xacro:property name="base_diameter" value="0.349"/>
  <xacro:property name="wheel_base" value="0.235"/>
  <!-- Body cylinder: top is 79mm above the floor, minus 12.5mm floor gap = 66.5mm tall.
       LiDAR housing sits on top (body top 79mm + 18mm housing = ~97mm total height). -->
  <xacro:property name="lower_cylinder_height" value="0.0665"/>
  <!-- LiDAR housing, measured 18mm, seated flush on the body top -->
  <xacro:property name="laser_puck_height" value="0.018"/>
  <xacro:property name="laser_puck_diameter" value="0.083"/>
  <!-- offset = laser_puck_height/2 so the housing bottom sits at the body top -->
  <xacro:property name="laser_puck_offset" value="0.009"/>
  <!-- LiDAR turret sits toward the REAR of the vacuum, not centered.
       +X is forward, so negative shifts it back. Measured: LiDAR center is
       78mm in from the rear edge -> 174.5mm radius - 78mm = 96.5mm behind center. -->
  <xacro:property name="lidar_center_offset" value="-0.0965"/>

  <!-- N*m -->
  <xacro:property name="motor_stall_torque" value="0.5"/>
  <xacro:property name="max_linear_acceleration" value="1"/>
  <xacro:property name="lower_cylinder_mass" value="2.500"/>
  <!-- caster and battery weight -->
  <xacro:property name="caster_mass" value="0.050"/>
  <xacro:property name="wheel_mass" value="0.100"/>
  <xacro:property name="laser_puck_mass" value="0.150"/>
  <!-- ****************** **************** ****************** -->

  <xacro:property name="DEG2RAD" value="0.0174533"/>
</robot>
