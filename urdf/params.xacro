<?xml version="1.0" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- ****************** ROBOT DIMENSIONS ****************** -->
  <!-- Units: meters, degrees, kg, N*m, m/s2 -->
  <!-- Proscenic M6 Pro: round body ~349mm dia, ~95mm tall (incl. LiDAR turret). -->
  <!-- wheel_base 0.233m matches vacuum_ros2_bridge WHEEL_BASE used for odometry. -->
  <!-- Values are approximate; refine against measurements of the physical robot. -->
  <xacro:property name="wheel_diameter" value="0.065"/>
  <xacro:property name="wheel_width" value="0.012"/>
  <xacro:property name="caster_diameter" value="0.025"/>
  <!-- Caster center to base edge -->
  <xacro:property name="caster_inset" value="0.030"/>
  <xacro:property name="floor_clearance" value="0.010"/>
  <xacro:property name="base_diameter" value="0.349"/>
  <xacro:property name="wheel_base" value="0.233"/>
  <!-- Flat vacuum body height (LiDAR turret adds on top) -->
  <xacro:property name="lower_cylinder_height" value="0.072"/>
  <!-- LiDAR turret/puck on top of the body -->
  <xacro:property name="laser_puck_height" value="0.018"/>
  <xacro:property name="laser_puck_diameter" value="0.070"/>
  <xacro:property name="laser_puck_offset" value="0.005"/>
  <xacro:property name="lidar_center_offset" value="0.000"/>

  <!-- N*m -->
  <xacro:property name="motor_stall_torque" value="0.5"/>
  <xacro:property name="max_linear_acceleration" value="1"/>
  <xacro:property name="lower_cylinder_mass" value="2.500"/>
  <!-- caster and battery weight -->
  <xacro:property name="caster_mass" value="0.050"/>
  <xacro:property name="wheel_mass" value="0.100"/>
  <xacro:property name="laser_puck_mass" value="0.150"/>
  <!-- ****************** **************** ****************** -->

  <xacro:property name="DEG2RAD" value="0.0174533"/>
</robot>
